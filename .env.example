AGENT_DATA_DIR=data
AGENT_DATABASE_URL=sqlite://data/agent.db
AGENT_API_KEY=local-dev-key
AGENT_API_SECRET=local-dev-secret
AGENT_SERVER_HOST=0.0.0.0
AGENT_SERVER_PORT=8080
AGENT_WEB_PORT=3000
AGENT_MAX_PARALLELISM=8
AGENT_MAX_GRAPH_DEPTH=6
AGENT_MAX_CONTEXT_TOKENS=16000
SKILLS_DIR=skills
AGENT_WEBHOOK_TIMEOUT_SECS=5
VLLM_BASE_URL=http://127.0.0.1:8000
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
GEMINI_API_KEY=your-gemini-api-key

# Route planner/reviewer/tool-caller/coder LLM traffic through a local CLI instead of direct APIs.
# MODEL_CLI_BACKEND=claude_code
# MODEL_CLI_COMMAND=claude
# MODEL_CLI_ARGS=--dangerously-skip-permissions
# MODEL_CLI_TIMEOUT_MS=300000
# MODEL_CLI_ONLY=true

# Coder-only backend (keeps the rest of the orchestrator on API/vLLM routing unless MODEL_CLI_BACKEND is also set)
# CODER_BACKEND=codex
# CODER_COMMAND=codex
# CODER_ARGS=--model o3
# CODER_TIMEOUT_MS=300000

# Gateway: Slack (optional - omit to disable Slack adapter)
# SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
# SLACK_SIGNING_SECRET=your-slack-signing-secret

# Gateway: Discord (optional - omit to disable Discord adapter)
# DISCORD_BOT_TOKEN=your-discord-bot-token
# DISCORD_APPLICATION_ID=123456789
# DISCORD_PUBLIC_KEY=hex-encoded-ed25519-public-key

# MCP (optional)
# MCP_ENABLED=true
# MCP_CONFIG_PATH=mcp_servers.json

# MCP server credentials & paths (referenced by mcp_servers.json via ${VAR})
# GITHUB_PERSONAL_ACCESS_TOKEN=your-github-pat
# TAVILY_API_KEY=your-tavily-api-key
# AGENT_WORKSPACE_DIR=/path/to/your/project
# AGENT_EXTRA_DIR=/path/to/extra/directory
